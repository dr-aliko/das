# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Django core ────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-real-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Database ───────────────────────────────────────────────────────────────
# Leave unset (or commented out) to use SQLite in development.
# DATABASE_URL=postgres://dasuser:password@localhost/dasdb

# ── External task API ──────────────────────────────────────────────────────
EXTERNAL_API_BASE_URL=http://152.70.23.159:5000/api
EXTERNAL_API_TIMEOUT=5

# ── Email ──────────────────────────────────────────────────────────────────
# Console backend is safe for dev — prints to terminal, sends nothing.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Vagus <noreply@vagus.tr>

# ── Feature flags ──────────────────────────────────────────────────────────
V2_SHELL_ENABLED=True
V2_DEFAULT=False
DESKTOP_V2_ENABLED=True
DESKTOP_V2_DEFAULT=True
DAS_FAST_ENTRY=False
